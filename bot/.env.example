# Telegram
BOT_TOKEN=your_bot_token
BOT_USERNAME=YourBotUsername

# Database (Railway: лучше DATABASE_PRIVATE_URL — без egress)
# DATABASE_PRIVATE_URL=postgresql://...  # приватный URL из сервиса PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admins (через запятую)
ADMIN_IDS=123456789,987654321

# CryptoBot (опционально)
CRYPTOBOT_API_TOKEN=
CRYPTOBOT_MERCHANT_ID=

# TON
TON_WALLET_ADDRESS=
TON_API_KEY=

# FreeKassa (обязательно для FreeKassa)
FREEKASSA_MERCHANT_ID=
FREEKASSA_SECRET_WORD_1=
FREEKASSA_SECRET_WORD_2=
FREEKASSA_SECRET_WORD_3=
FREEKASSA_WEBHOOK_SECRET=

# Цены и лимиты (1 Star = 0.0175 USD). Курс TON: по умолчанию Binance TONUSDT
USD_PER_STAR=0.0175
# TON_USD_RATE=1.33   # или 0.751 (TON за 1$) — фиксированный курс
# TON_USD_URL=        # по умолчанию Binance; можно задать CoinGecko и т.п.
PRICE_UPDATE_INTERVAL=600
MIN_STARS_PER_ORDER=50
MAX_STARS_PER_ORDER=50000
REFERRAL_PERCENT=10

# Антифрод
ANTIFRAUD_MAX_ORDERS_PER_MINUTE=3

# Дополнительно
SUPPORT_LINK=https://t.me/support
# URL вашего приложения для webhook FreeKassa (например https://your-app.railway.app)
WEBHOOK_BASE_URL=
# ID канала/группы для заказов (добавьте бота в канал как админа). Пример: -1001234567890
# ORDERS_CHANNEL_ID=
